# Šmogyho FVE — konfigurace. Zkopíruj jako .env a vyplň hodnoty.
# (.env se necommituje do gitu — je v .gitignore)

# Port, na kterém appka poběží (na NASu si zvol volný port)
PORT=3000

# --- Solax (střídač FVE) ---
SOLAX_TOKEN_ID=
SOLAX_SN=

# --- Shelly (relé: bojler, bazén, solinátor, světla) ---
SHELLY_AUTH_KEY=
SHELLY_SERVER_URI=
SHELLY_DEVICE_ID=
POOL_DEVICE_ID=
SOLINATOR_DEVICE_ID=
# volitelně, jinak = SHELLY_SERVER_URI:
# POOL_SERVER_URI=
# SOLINATOR_SERVER_URI=

# --- Panasonic klimatizace + tepelné čerpadlo ---
PANASONIC_EMAIL=
PANASONIC_PASSWORD=

# --- TaHoma / Somfy (žaluzie) ---
TAHOMA_EMAIL=
TAHOMA_PASSWORD=

# --- Solax wallbox ---
WALLBOX_SN=

# --- Asistent (Claude) ---
ANTHROPIC_API_KEY=

# --- Nuki zámek ---
NUKI_TOKEN=

# --- Infigy (teplota bojleru atd.) ---
INFIGY_EMAIL=
INFIGY_PASSWORD=

# --- Počasí (volitelné) ---
OWM_API_KEY=

# --- Push notifikace (volitelné) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:smogrovic@gmail.com

# POZOR: APP_PIN nenastavuj — zamykání appky je vypnuté.
# RENDER_EXTERNAL_URL nenastavuj — self-ping je jen pro Render, na NASu netřeba.
